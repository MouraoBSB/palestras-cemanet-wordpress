# Configuração de acesso à REST API do WordPress — CEMANET
# Copie este arquivo para ".env" e preencha com os valores reais.
# O ".env" é ignorado pelo git e NUNCA deve ser versionado.

# URL base do site
WP_BASE_URL=https://cemanet.org.br

# Usuário do WordPress (login)
WP_USER=

# Senha de aplicativo (Application Password) — gerada no perfil do usuário.
# NÃO use a senha principal da conta aqui.
WP_APP_PASSWORD=
